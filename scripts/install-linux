#!/usr/bin/env bash
set -euo pipefail

# Linux installer — runs both as `scripts/install-linux` (in-repo) and
# as the bundled `install` script inside the release tarball (renamed
# by scripts/release / the CI release workflow). When invoked by the
# self-updater, $SCRIPT_DIR points at the staged release root.

# ── 0. Escape the parent cgroup ─────────────────────────────────────
# When the BEAM spawns this script via Port.open + setsid (Handoff),
# the script inherits scry-2.service's cgroup. KillMode=mixed kills
# every process in that cgroup the moment the unit stops — and the
# unit stops the moment we issue `systemctl --user stop scry-2.service`
# (or the BEAM finishes exiting). We get SIGKILLed mid-install with
# the new unit never started. Fix: re-exec ourselves under
# `systemd-run --user --scope` which moves the process into a fresh
# scope unit owned by the user manager, in its own cgroup, independent
# of scry-2.service. SCRY2_INSTALL_REEXECED guards against recursion;
# falling through on systemd-run failure is better than crashing.
if [ -z "${SCRY2_INSTALL_REEXECED:-}" ] && command -v systemd-run >/dev/null 2>&1; then
  export SCRY2_INSTALL_REEXECED=1
  if systemd-run --user --scope --collect --quiet -- "$0" "$@"; then
    exit 0
  fi
  echo "Warning: systemd-run failed; continuing without cgroup escape." >&2
  unset SCRY2_INSTALL_REEXECED
fi

INSTALL_DIR="$HOME/.local/lib/scry_2"
UNIT_PATH="$HOME/.config/systemd/user/scry-2.service"
DESKTOP_PATH="$HOME/.local/share/applications/scry-2.desktop"
LEGACY_AUTOSTART="$HOME/.config/autostart/scry2.desktop"
LEGACY_UNIT_PATH="$HOME/.config/systemd/user/scry_2.service"
LEGACY_DESKTOP_PATH="$HOME/.local/share/applications/scry_2.desktop"
SERVICE="scry-2.service"
LEGACY_SERVICE="scry_2.service"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# When run from the in-app self-updater, the BEAM spawns this script
# under `env -i` with a small whitelist. systemctl --user works in
# that whitelist (XDG_RUNTIME_DIR + DBUS_SESSION_BUS_ADDRESS + HOME
# are present); xdg-open + browser launch don't run from this script
# anymore, so we no longer need to rehydrate DISPLAY / WAYLAND_DISPLAY.

echo "Installing Scry2 (systemd user service)..."

# ── 1. Stop anything already running ────────────────────────────────
# Old tray-based install: kill scry2-tray + autostart entry. Idempotent
# — these run no-op on a fresh system.
if pgrep -x scry2-tray &>/dev/null; then
  echo "Stopping legacy Scry2 tray..."
  pkill -x scry2-tray 2>/dev/null || true
  sleep 1
fi
if [ -f "$LEGACY_AUTOSTART" ]; then
  echo "Removing legacy autostart entry..."
  rm -f "$LEGACY_AUTOSTART"
fi

# Stop the systemd unit if it's already running so file replacement
# doesn't fight an active BEAM. `is-active` exits non-zero on
# inactive — guard against set -e.
if systemctl --user is-active --quiet "$SERVICE" 2>/dev/null; then
  echo "Stopping running Scry2 service..."
  systemctl --user stop "$SERVICE"
fi

# v0.37.1 renamed the unit from scry_2.service to scry-2.service. On
# upgrade from v0.36.x / v0.37.0, stop and remove the old unit so we
# don't end up with two copies of Scry2 fighting for the same install
# dir and port.
if systemctl --user is-active --quiet "$LEGACY_SERVICE" 2>/dev/null; then
  echo "Stopping legacy $LEGACY_SERVICE..."
  systemctl --user stop "$LEGACY_SERVICE"
fi
systemctl --user disable "$LEGACY_SERVICE" 2>/dev/null || true
if [ -f "$LEGACY_UNIT_PATH" ]; then
  echo "Removing legacy $LEGACY_UNIT_PATH..."
  rm -f "$LEGACY_UNIT_PATH"
fi
if [ -f "$LEGACY_DESKTOP_PATH" ]; then
  rm -f "$LEGACY_DESKTOP_PATH"
fi

# Belt-and-braces: stop any orphaned BEAM that wasn't under systemd
# (e.g. user started it manually before the systemd switch).
if [ -x "$INSTALL_DIR/bin/scry_2" ]; then
  "$INSTALL_DIR/bin/scry_2" stop 2>/dev/null || true
fi

# ── 2. Replace install directory ────────────────────────────────────
echo "Copying files to $INSTALL_DIR..."
rm -rf "$INSTALL_DIR"
mkdir -p "$INSTALL_DIR"
cp -r "$SCRIPT_DIR/." "$INSTALL_DIR/"

# ── 3. Install systemd unit ─────────────────────────────────────────
# The unit template lives next to the release in `scry-2.service` —
# scripts/release / CI copies it into the package alongside `install`.
# We materialise it under ~/.config/systemd/user/ with the staged
# install dir patched into ExecStart / ExecStop.
echo "Installing systemd unit..."
mkdir -p "$(dirname "$UNIT_PATH")"
sed \
  -e "s|/path/to/scry_2/bin/scry_2 start|$INSTALL_DIR/bin/scry_2 start|" \
  -e "s|/path/to/scry_2/bin/scry_2 stop|$INSTALL_DIR/bin/scry_2 stop|" \
  "$INSTALL_DIR/scry-2.service" > "$UNIT_PATH"

# ── 4. Install desktop launcher ─────────────────────────────────────
echo "Installing desktop launcher..."
mkdir -p "$(dirname "$DESKTOP_PATH")"
cp "$INSTALL_DIR/scry-2.desktop" "$DESKTOP_PATH"
# Refresh the desktop database so the entry shows up in launchers
# without a re-login. update-desktop-database is part of
# desktop-file-utils — present on most desktops, optional here.
if command -v update-desktop-database &>/dev/null; then
  update-desktop-database "$(dirname "$DESKTOP_PATH")" 2>/dev/null || true
fi

# ── 5. Clear stale apply.lock ───────────────────────────────────────
DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/scry_2"
rm -f "$DATA_DIR/apply.lock"

# ── 6. Reload + enable + start ──────────────────────────────────────
systemctl --user daemon-reload
systemctl --user enable "$SERVICE" >/dev/null 2>&1 || systemctl --user enable "$SERVICE"
systemctl --user start "$SERVICE"

# Linger keeps the user manager running across logout — the service
# stays up while the machine is up, regardless of an active session.
# Quietly ignored if loginctl isn't available (rare on systemd hosts).
loginctl enable-linger "$USER" 2>/dev/null || true

echo ""
echo "Scry2 installed and running under systemd."
echo "  URL:     http://localhost:6015"
echo "  Logs:    journalctl --user -u $SERVICE -f"
echo "  Stop:    systemctl --user stop $SERVICE"
echo "  Status:  systemctl --user status $SERVICE"
echo ""
echo "Uninstall: $INSTALL_DIR/uninstall"
