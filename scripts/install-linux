#!/usr/bin/env bash
set -euo pipefail

INSTALL_DIR="$HOME/.local/lib/scry_2"
DESKTOP_FILE="$HOME/.config/autostart/scry2.desktop"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# When run from the in-app self-updater on Scry2 ≤ 0.25.2, the BEAM
# spawns this script under `env -i` with a whitelist that did not
# include DISPLAY / WAYLAND_DISPLAY / XAUTHORITY. Without those, the
# tray we relaunch below crashes with "Gtk-WARNING: cannot open
# display:" and the BEAM never starts. Rehydrate the GUI session env
# from systemd if it's missing — XDG_RUNTIME_DIR + DBUS were always in
# the whitelist, so `systemctl --user` works in the stripped env.
if [ -z "${DISPLAY:-}" ] && [ -z "${WAYLAND_DISPLAY:-}" ] && command -v systemctl &>/dev/null; then
    while IFS= read -r line; do
        export "$line"
    done < <(systemctl --user show-environment 2>/dev/null \
             | grep -E '^(DISPLAY|WAYLAND_DISPLAY|XAUTHORITY|XDG_SESSION_TYPE|XDG_CURRENT_DESKTOP)=')
fi

echo "Installing Scry2..."

# Stop existing backend and tray if running
if [ -x "$INSTALL_DIR/bin/scry_2" ]; then
    echo "Stopping existing Scry2 backend..."
    "$INSTALL_DIR/bin/scry_2" stop 2>/dev/null || true
fi
if pgrep -x scry2-tray &>/dev/null; then
    echo "Stopping existing Scry2 tray..."
    pkill -x scry2-tray 2>/dev/null || true
    sleep 1
fi

# Copy release files
echo "Copying files to $INSTALL_DIR..."
rm -rf "$INSTALL_DIR"
mkdir -p "$INSTALL_DIR"
cp -r "$SCRIPT_DIR/." "$INSTALL_DIR/"
chmod +x "$INSTALL_DIR/scry2-tray"

# Enable autostart on login via XDG
mkdir -p "$(dirname "$DESKTOP_FILE")"
cat > "$DESKTOP_FILE" << EOF
[Desktop Entry]
Type=Application
Name=Scry2
Exec=$INSTALL_DIR/scry2-tray
Hidden=false
NoDisplay=false
X-GNOME-Autostart-enabled=true
EOF

# Clear any stale update lock from previous crash or successful apply
DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/scry_2"
rm -f "$DATA_DIR/apply.lock"

# Launch tray (which will start the backend)
echo "Starting Scry2..."
"$INSTALL_DIR/scry2-tray" &

echo ""
echo "Scry2 installed! It will start automatically on login."
echo "Access your stats at: http://localhost:6015"
echo ""
echo "To uninstall later, run: $INSTALL_DIR/uninstall"
echo ""
echo "Note: On GNOME, install 'gnome-shell-extension-appindicator' if the tray icon does not appear."
