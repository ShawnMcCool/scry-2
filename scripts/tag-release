#!/usr/bin/env bash
set -euo pipefail

VERSION="${1:-}"
if [[ -z "$VERSION" ]]; then
    echo "Usage: scripts/tag-release <version>"
    echo "  e.g. scripts/tag-release 0.2.0"
    exit 1
fi

TAG="v${VERSION}"

# Ensure version looks like semver
if ! [[ "$VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo "Error: version must be semver (e.g. 0.2.0)"
    exit 1
fi

# Sync with remote to avoid tagging on stale local state
echo "Fetching from remote..."
jj git fetch

# Run precommit checks — catches broken builds and format drift before tagging
echo "Running precommit checks..."
mix precommit

# Ensure working copy is clean (precommit may have formatted files)
if jj diff --summary 2>/dev/null | grep -q .; then
    echo "Error: working copy has uncommitted changes after precommit (mix format likely changed files)."
    echo "Review, commit the changes, then re-run scripts/tag-release."
    jj diff --summary
    exit 1
fi

# Bump version in mix.exs
echo "Bumping version in mix.exs to $VERSION..."
VERSION="$VERSION" python3 -c "
import re, sys, os
version = os.environ['VERSION']
content = open('mix.exs').read()
if not re.search(r'version: \"[^\"]+\"', content):
    sys.exit('Error: version pattern not found in mix.exs')
updated = re.sub(r'version: \"[^\"]+\"', f'version: \"{version}\"', content)
with open('mix.exs', 'w') as f:
    f.write(updated)
print('mix.exs updated')
"

# Rotate CHANGELOG.md: rename `## [Unreleased]` to `## vX.Y.Z — DATE`
# and seed a fresh empty Unreleased section. Whatever sits between the
# old Unreleased header and the next `## v` header becomes the body of
# the release on GitHub and the in-app "What's new" disclosure.
TODAY="$(date +%Y-%m-%d)"
if [[ -f CHANGELOG.md ]]; then
    echo "Rotating CHANGELOG.md..."
    VERSION="$VERSION" TODAY="$TODAY" python3 <<'PY'
import os, re, sys
version = os.environ['VERSION']
today = os.environ['TODAY']
path = 'CHANGELOG.md'
content = open(path).read()
if '## [Unreleased]' not in content:
    sys.exit(f'Error: `## [Unreleased]` header not found in {path}')
new_header = f'## [Unreleased]\n\n## v{version} — {today}'
updated = content.replace('## [Unreleased]', new_header, 1)
with open(path, 'w') as f:
    f.write(updated)
print(f'CHANGELOG.md rotated: v{version} — {today}')
PY
else
    echo "Note: CHANGELOG.md not found, skipping rotation."
fi

# Describe the jj change (includes mix.exs + CHANGELOG.md rotation)
jj describe -m "chore: release ${TAG}"

# Capture the change ID before tagging (tagging makes @ immutable and creates a new empty commit)
RELEASE_CHANGE=$(jj log -r @ --no-graph -T 'change_id')

# Create the git tag at the current revision
echo "Creating tag ${TAG}..."
jj tag set "${TAG}"

# Move main bookmark to the release commit so CI workflows trigger on main
echo "Setting main bookmark..."
jj bookmark set main -r "${RELEASE_CHANGE}"

# Push main bookmark and the tag
echo "Pushing main to remote..."
jj git push -b main

echo "Pushing tag to remote..."
git push origin "refs/tags/${TAG}"

echo ""
echo "Released ${TAG}. GitHub Actions will build and publish the release."
REPO=$(jj git remote list 2>/dev/null | grep origin | awk '{print $2}' | sed 's|.*github.com[:/]||;s|\.git$||')
if [[ -n "$REPO" ]]; then
    echo "Monitor at: https://github.com/${REPO}/actions"
fi
