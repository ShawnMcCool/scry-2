#!/usr/bin/env bash
set -euo pipefail

# Install the always-on local systemd user service for scry_2.
#
# This runs the working-tree (dev) code as the user's everyday instance on
# port 6015 against the real production database. It deliberately does NOT
# start while the packaged release service (scry-2.service) is active — two
# processes writing the same SQLite database risks corruption. Retire the
# release first (the cutover), then re-run this.
#
# Usage: scripts/install-dev

cd "$(dirname "$0")/.."

banner() { echo "==> $1"; }

source_dir="$(pwd)"
unit_src="defaults/scry-2-dev.service"
unit_dst="$HOME/.config/systemd/user/scry-2-dev.service"
service_name="scry-2-dev"

# 1. Install patched systemd unit
banner "Installing systemd unit to $unit_dst"
mkdir -p "$(dirname "$unit_dst")"
sed \
  -e "s|WorkingDirectory=.*|WorkingDirectory=$source_dir|" \
  "$unit_src" > "$unit_dst"

# 2. Reload systemd and enable at login
banner "Reloading systemd"
systemctl --user daemon-reload
systemctl --user enable "$service_name"

# 3. Safety: refuse to start alongside the packaged release on the same port/DB
if systemctl --user is-active --quiet scry-2.service; then
  banner "Release service scry-2.service is still active — NOT starting"
  echo "  The packaged release is running on the same port + database."
  echo "  Retire it first, then start this instance:"
  echo "    systemctl --user disable --now scry-2.service"
  echo "    systemctl --user start $service_name"
  echo "  (Back up the database before the first start — migrations run on boot.)"
  exit 0
fi

# 4. Start or restart the unified instance
if systemctl --user is-active --quiet "$service_name"; then
  banner "Restarting service"
  systemctl --user restart "$service_name"
else
  banner "Starting service"
  systemctl --user start "$service_name"
fi

# 5. Validate readiness (waits out migrations on first/large boots)
banner "Health check"
if scripts/healthcheck; then
  health="healthy"
else
  health="NOT READY — see output above and journalctl"
fi

# 6. Status summary
banner "Install complete"
echo "  Source:  $source_dir"
echo "  Unit:    $unit_dst"
echo "  URL:     http://localhost:6015"
echo "  Health:  $health  (scripts/healthcheck)"
echo "  Logs:    journalctl --user -u $service_name -f"
echo "  REPL:    iex --name repl@127.0.0.1 --remsh scry_2_dev@127.0.0.1"
