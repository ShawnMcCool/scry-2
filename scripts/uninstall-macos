#!/usr/bin/env bash
set -euo pipefail

PLIST_LABEL="com.scry2"
PLIST_FILE="$HOME/Library/LaunchAgents/${PLIST_LABEL}.plist"
INSTALL_DIR="$HOME/.local/lib/scry_2"
DATA_DIR="$HOME/Library/Application Support/scry_2"
CONFIG_DIR="$HOME/.config/scry_2"
DB_FILE="$DATA_DIR/scry_2.db"

echo "Uninstalling Scry2..."

# Unload launch agent and stop tray
if launchctl list "$PLIST_LABEL" &>/dev/null; then
    launchctl unload "$PLIST_FILE" 2>/dev/null || true
fi
pkill -x scry2-tray 2>/dev/null || true

# Stop backend directly in case tray was not running
if [[ -f "$INSTALL_DIR/bin/scry_2" ]]; then
    "$INSTALL_DIR/bin/scry_2" stop 2>/dev/null || true
fi

# Remove plist and install directory (binaries only — data dir is untouched)
rm -f "$PLIST_FILE"
if [[ -d "$INSTALL_DIR" ]]; then
    rm -rf "$INSTALL_DIR"
    echo "Removed $INSTALL_DIR"
fi

echo ""
echo "Scry2 has been uninstalled."
echo ""
echo "Your database has NOT been deleted."
echo ""

if [[ -f "$DB_FILE" ]]; then
    DB_SIZE=$(du -h "$DB_FILE" | cut -f1)
    echo "  Database: $DB_FILE"
    echo "  Size:     $DB_SIZE"
else
    echo "  Database: $DB_FILE (not found)"
fi

echo "  Config:   $CONFIG_DIR/config.toml"
echo ""
echo "If you want to delete your database and config, run:"
echo "  rm -rf \"$DATA_DIR\" \"$CONFIG_DIR\""
echo ""
