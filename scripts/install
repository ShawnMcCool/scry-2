#!/usr/bin/env bash
set -euo pipefail

# Developer-local install: builds the production release from source and
# installs it on this machine. For developers who work on the repo AND
# run the production app locally for their own gameplay analysis.
#
# This is a convenience wrapper that:
#   1. Runs scripts/release to build + stage the package at
#      _build/prod/package/
#   2. Runs the staged platform installer from inside that directory
#
# The staged installer is one of:
#   scripts/install-linux   (Linux — XDG autostart + tray)
#   scripts/install-macos   (macOS — LaunchAgent + tray)
#
# Usage:
#   scripts/install
#
# For CI-built multi-platform releases see CLAUDE.md.

cd "$(dirname "$0")/.."

banner() { echo "==> $1"; }

banner "Building release"
scripts/release

banner "Installing"
(cd _build/prod/package && bash ./install)
