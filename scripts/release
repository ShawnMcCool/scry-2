#!/usr/bin/env bash
set -euo pipefail

# Build a production release for the current platform.
# Stages the result in _build/prod/package/ — ready to install.
#
# Usage:
#   scripts/release          # build and stage
#   scripts/install          # build, stage, and install locally (for devs
#                            #   who run the production app on their own
#                            #   machine for gameplay analysis)

cd "$(dirname "$0")/.."

VERSION=$(grep -oP '(?<=version: ")[^"]+' mix.exs)

banner() { echo "==> $1"; }

banner "Building Elixir assets"
MIX_ENV=prod mix assets.deploy

banner "Building Elixir release"
MIX_OS_DEPS_COMPILE_PARTITION_COUNT=8 MIX_ENV=prod mix release

banner "Building tray binary"
case "$(uname -s)" in
  Linux)
    (cd tray && go build -ldflags="-X 'scry2/tray/updater.CurrentVersion=${VERSION}'" -o ../scry2-tray .)
    install_script="scripts/install-linux"
    uninstall_script="scripts/uninstall-linux"
    ;;
  Darwin)
    (cd tray && go build -ldflags="-X 'scry2/tray/updater.CurrentVersion=${VERSION}'" -o ../scry2-tray .)
    install_script="scripts/install-macos"
    uninstall_script="scripts/uninstall-macos"
    ;;
  *)
    echo "Error: local builds not supported on $(uname -s)."
    echo "Windows builds are CI-only — see .github/workflows/release.yml"
    exit 1
    ;;
esac

banner "Staging package"
package="_build/prod/package"
rm -rf "$package"
mkdir -p "$package"
cp -r _build/prod/rel/scry_2/. "$package/"
cp scry2-tray "$package/"
cp "$install_script" "$package/install"
cp "$uninstall_script" "$package/uninstall"
chmod +x "$package/install" "$package/uninstall" "$package/scry2-tray"

banner "Release staged at $package"
echo "  Install locally:  scripts/install"
echo "  Manual install:   cd $package && ./install"
