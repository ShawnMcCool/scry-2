<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <!-- Directory layout for Scry2 installation.
       Install to C:\Program Files\Scry2.
       Subdirectories (bin, erts-*, lib, releases) are created automatically
       by the Files element in Components.wxs.
       Data stays in %APPDATA%\scry_2 (not managed by MSI). -->

  <Fragment>
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="Scry2" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ScryMenuFolder" Name="Scry2" />
    </StandardDirectory>
  </Fragment>
</Wix>
