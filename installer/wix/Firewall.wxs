<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:firewall="http://wixtoolset.org/schemas/v4/wxs/firewall">

  <!-- Firewall exceptions for the BEAM runtime.
       epmd (Erlang Port Mapper Daemon) and erl (the VM) need inbound TCP
       on the local subnet for distributed Erlang. Scoped to localSubnet
       to minimize exposure. Removed automatically on uninstall.

       These reference installed file paths rather than File elements since
       the ERTS files are auto-included via the Files element. -->

  <Fragment>
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="EpmdFirewall" Guid="*">
        <RegistryValue Root="HKLM"
                       Key="Software\Scry2"
                       Name="EpmdFirewall"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
        <firewall:FirewallException Id="EpmdRule"
                                    Name="Scry2 EPMD"
                                    Program="[INSTALLFOLDER]$(var.ErtsVersion)\bin\epmd.exe"
                                    Scope="localSubnet"
                                    Protocol="tcp" />
      </Component>

      <Component Id="ErlFirewall" Guid="*">
        <RegistryValue Root="HKLM"
                       Key="Software\Scry2"
                       Name="ErlFirewall"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
        <firewall:FirewallException Id="ErlRule"
                                    Name="Scry2 Erlang VM"
                                    Program="[INSTALLFOLDER]$(var.ErtsVersion)\bin\erl.exe"
                                    Scope="localSubnet"
                                    Protocol="tcp" />
      </Component>
    </DirectoryRef>
  </Fragment>
</Wix>
