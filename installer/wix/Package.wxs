<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <!--
    Main MSI package definition for Scry2.
    UpgradeCode is permanent — never change it across versions.
    Version is stamped by CI via -d Version=X.Y.Z.
  -->
  <Package Name="Scry2"
           Manufacturer="Shawn McCool"
           Version="$(var.Version)"
           UpgradeCode="35ed2438-5d9c-41b9-a073-b8eafdc2fde6"
           Scope="perMachine"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Scry2 is already installed."
                  Schedule="afterInstallInitialize" />

    <MediaTemplate EmbedCab="yes" />

    <!-- Pull in the feature tree from Features.wxs -->
    <FeatureRef Id="Complete" />

    <!-- Kill scry2-tray.exe before upgrading files.
         The tray's shutdown handler stops the Erlang backend. -->
    <util:CloseApplication Id="CloseTray"
                           Target="scry2-tray.exe"
                           CloseMessage="yes"
                           RebootPrompt="no"
                           TerminateProcess="1"
                           Description="Scry2 system tray"
                           Sequence="1" />

    <!-- Launch the tray after install/upgrade — not on uninstall.
         WixShellExec uses ShellExecuteEx so the process runs in the user's
         desktop session even though the MSI itself runs elevated as SYSTEM. -->
    <Property Id="WixShellExecTarget" Value="[INSTALLFOLDER]scry2-tray.exe" />
    <CustomAction Id="LaunchTray"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixShellExec"
                  Execute="immediate"
                  Return="ignore" />

    <!-- Recursively delete INSTALLFOLDER after RemoveFiles on uninstall.
         WixRemoveFoldersEx cannot be used here — it runs before directory
         properties are established in the MSI session (timing issue).
         Instead we use a two-step pattern:
           1. SetProperty (immediate) captures [INSTALLFOLDER] into CustomActionData
              while the property is still defined.
           2. WixQuietExec64 (deferred, elevated) runs cmd.exe /c rmdir /s /q
              against the captured path after RemoveFiles has finished. -->
    <SetProperty Id="DeleteInstallDir"
                 Before="DeleteInstallDir"
                 Sequence="execute"
                 Value="cmd.exe /c rmdir /s /q &quot;[INSTALLFOLDER]&quot;" />
    <CustomAction Id="DeleteInstallDir"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="LaunchTray" After="InstallFinalize" Condition="NOT REMOVE" />
      <Custom Action="DeleteInstallDir" After="RemoveFiles" Condition="Installed AND REMOVE~=&quot;ALL&quot;" />
    </InstallExecuteSequence>

  </Package>
</Wix>
